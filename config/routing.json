{
  "name": "Happ Routing",
  "repository": "ldkt/happ-routing",
  "globalProxy": false,
  "domainStrategy": "IPIfNonMatch",
  "dns": {
    "remote": {
      "type": "DoH",
      "domain": "https://cloudflare-dns.com/dns-query",
      "ip": "1.1.1.1"
    },
    "domestic": {
      "type": "DoH",
      "domain": "https://dns.google/dns-query",
      "ip": "8.8.8.8"
    }
  },
  "rules": {
    "directSites": [
      "geosite:private",
      "geosite:happ-direct"
    ],
    "directIp": [
      "geoip:private"
    ],
    "proxySites": [
      "geosite:happ-proxy"
    ],
    "proxyIp": [],
    "blockSites": [
      "geosite:category-ads-all",
      "geosite:happ-block"
    ],
    "blockIp": []
  },
  "outboundTags": {
    "direct": "direct",
    "proxy": "proxy",
    "block": "block"
  }
}
