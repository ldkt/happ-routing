{
  "name": "urdb-home-assistant-frontend",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build:frontend": "esbuild custom_components/urdb/frontend/src/urdb-card.js --bundle --format=esm --target=es2022 --outfile=custom_components/urdb/frontend/urdb-card.js && node scripts/normalize-frontend-bundle.mjs",
    "test:frontend": "npm run build:frontend && node --test tests/frontend/urdb-card.test.mjs"
  },
  "dependencies": {
    "lit": "3.3.1"
  },
  "devDependencies": {
    "esbuild": "0.25.8",
    "happy-dom": "18.0.1"
  }
}
